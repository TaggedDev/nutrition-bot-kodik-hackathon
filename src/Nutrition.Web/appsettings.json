{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "OpenFoodFacts": {
    "BaseUrl": "https://world.openfoodfacts.org/",
    "SearchBaseUrl": "https://search.openfoodfacts.org/",
    "SearchPageSize": 15,
    "CacheTtlHours": 12,
    "SearchRequestsPerMinute": 8,
    "HttpTimeoutSeconds": 20,
    "EnableLegacyCgiFallback": false
  },
  "AllowedHosts": "*"
}
